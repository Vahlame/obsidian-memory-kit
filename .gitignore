# Go daemon local build (see AGENTS.md)
/bin/
/obsidian-memoryd
/obsidian-memoryd.exe

# Editors (local-only; the kit no longer commits workspace settings —
# the initializer writes <vault>/.vscode/settings.json into the user's vault instead)
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
desktop.ini

# Local backups
*.bak
*.orig

# Local tooling
node_modules/
.pnpm-store/
yarn.lock

# Python (obsidian-memory-rag local dev / pytest)
__pycache__/
*.py[cod]
*.egg-info/

# Temp extracts (CI / local linting)
tmp/
/prompt-ps-extract/

# Cursor / agent caches if anyone uses them at the repo root
.cursor/*
!.cursor/rules/
!.cursor/rules/**

# Claude Code local project state (permissions allowlist, launch config, task
# locks) — machine-specific, never meant to ship in the repo.
.claude/

# Local FTS5 sidecar (obsidian-memory-rag); keep indexes out of git
**/.obsidian-memory-rag/

# uv lockfile — this package is installed via `pip install -e .[extras]`
# (see AGENTS.md), not `uv sync`; a locally-generated uv.lock is an incidental
# dev artifact, not part of the documented reproducible-install path.
**/uv.lock
